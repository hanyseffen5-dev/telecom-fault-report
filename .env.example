# رابط Web App المنشور من Apps Script (ينتهي بـ /exec)
APPS_SCRIPT_URL=https://script.google.com/macros/s/YOUR_DEPLOYMENT_ID/exec

# للتطوير المحلي: اترك appsScriptUrl فارغاً في public/config.js
# للاستضافة الثابتة (GitHub Pages): ضع نفس الرابط في public/config.js → appsScriptUrl

# الخيار البديل: ضع credentials.json في جذر المشروع للاتصال المباشر بالشيت
# GOOGLE_APPLICATION_CREDENTIALS=./credentials.json
